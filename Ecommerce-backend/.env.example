# ==========================================
# V-RETAIL PRODUCTION ENVIRONMENT CONFIGURATION
# ==========================================

# 1. CORE SERVER SETTINGS
PORT=5000                              # Local development port (default: 5000)
NODE_ENV=development                   # Set to 'production' on your hosting platform
JWT_SEC=your_very_strong_random_secret # Use a long, random string (at least 32 chars)

# 2. DATABASE CONFIGURATION
# MongoDB Connection String (from MongoDB Atlas or local)
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/vretail_db

# 3. FRONTEND & SECURITY
# The URL where your frontend is hosted (used for CORS and payment redirects)
Frontend_Url=http://localhost:5173
# For VITE Frontend: VITE_SERVER_URL=https://your-api-domain.com

# 4. CLOUDINARY SETTINGS (Product Image Hosting)
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# 5. STRIPE PAYMENT GATEWAY
# Get these from your Stripe Dashboard (Developers > API keys)
Stripe_Secret_Key=sk_test_...
Stripe_Publishable_Key=pk_test_...

# 6. MAIL CONFIGURATION (SMTP)
# Used for OTP Login and Order Confirmation emails
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password        # Use an 'App Password', not your main account password
# (Previous names Gmail/Password are deprecated)

# ==========================================
# END OF CONFIGURATION
# ==========================================
